PORT=8000

# MongoDB (share the same URI with all teammates)
MONGO_URI=your_mongodb_connection_string

# JWT — ⚠️ ALL TEAM MEMBERS MUST USE THE EXACT SAME VALUE
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_shared_jwt_secret
JWT_EXPIRE=1d

# Email SMTP (for OTP verification & password reset)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# Frontend URL
CLIENT_URL=http://localhost:5173

# Groq AI (for roadmap generation)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-8b-8192

# ─────────────────────────────────────────────────────────────
# ADMIN SETUP — Run ONCE after cloning the repo:
#   node scripts/seedAdmin.js
# Creates: admin@skillrise.com / adminpassword123
# ─────────────────────────────────────────────────────────────
