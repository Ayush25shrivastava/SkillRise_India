# Gemini Round-Robin Pool (used by llmFactory.js)
GOOGLE_API_KEY_1=your_gemini_api_key_1
GOOGLE_API_KEY_2=your_gemini_api_key_2
GOOGLE_API_KEY_3=your_gemini_api_key_3

# Groq Fallback
GROK_API_KEY=your_groq_api_key

# Server Configs
PORT=5002

# Hybrid Memory Connections
MONGO_URI=your_mongodb_connection_string
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=chat-memory
PINECONE_NAMESPACE=chat-memory

# Language Model Secrets
HF_TOKEN=your_huggingface_token  # Required for generating vector embeddings
